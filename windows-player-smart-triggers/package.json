{
  "name": "digipal-player-smart-triggers",
  "version": "2.2.0",
  "description": "Digipal Digital Signage Player for Windows with Smart Triggers Hardware Support",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "rebuild": "electron-rebuild"
  },
  "author": "Digipal",
  "license": "MIT",
  "dependencies": {
    "midi": "^2.0.0",
    "node-hid": "^3.0.0",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "electron-rebuild": "^3.2.0"
  },
  "build": {
    "appId": "com.digipal.player.smart-triggers",
    "productName": "Digipal Player (Smart Triggers)",
    "asar": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  }
}
