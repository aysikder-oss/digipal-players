{
  "name": "digipal-player-smart-triggers",
  "version": "2.2.2",
  "description": "Digipal Digital Signage Player for Windows (Smart Triggers)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "author": "Digipal",
  "license": "MIT",
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.digipal.player.smart",
    "productName": "Digipal Player Smart",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  },
  "homepage": "https://digipal.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/aysikder-oss/digipal-players.git"
  }
}
