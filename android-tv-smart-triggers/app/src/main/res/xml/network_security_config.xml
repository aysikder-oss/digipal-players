<?xml version="1.0" encoding="utf-8"?>
<!--
    Cleartext HTTP is required for local server connections (e.g. http://192.168.x.x:8787).
    Android's domain-config does not support CIDR/IP-range matching, so base-config
    must allow cleartext globally. The smart triggers app only connects to locally
    discovered servers on the private network.
    Cloud connections always use HTTPS (digipalsignage.com).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
